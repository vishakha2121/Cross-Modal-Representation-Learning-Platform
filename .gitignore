# Create .gitignore file
@"
# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.coverage
htmlcov/

# ============================================
# Node / React / JavaScript
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.dist/
.cache/
.parcel-cache/
build/
dist/
*.log

# ============================================
# Environment Variables
# ============================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ============================================
# IDE / Editor Files
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================
# Database Files
# ============================================
*.db
*.sqlite
*.sqlite3
*.dump

# ============================================
# Uploads / Media
# ============================================
uploads/
media/
static/
logs/
*.log
tmp/
*.tmp
*.temp

# ============================================
# Model Files / Weights
# ============================================
models_weights/
*.pth
*.pt
*.h5
*.pb
*.onnx
*.ckpt

# ============================================
# OS Files
# ============================================
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
"@ | Out-File -FilePath .gitignore -Encoding utf8